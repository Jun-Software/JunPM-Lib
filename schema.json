{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Pack Schema",
    "description": "A JSON schema for JunPM.",
    "type": "object",
    "properties": {
        "name": {
            "description": "Pack Name",
            "type": "string"
        },
        "type": {
            "description": "Pack Type",
            "type": "string",
            "enum": ["lib", "whl"]
        },
        "versions": {
            "description": "Pack URL",
            "type": "object",
            "minItems": 1,
            "uniqueItems": true,
            "properties": {
                "latest": {
                    "type": "string"
                }
            },
            "additionalProperties": true,
            "required": [
                "latest"
            ]
        }
    },
    "required": [
        "name", 
        "type", 
        "versions"
    ],
    "additionalProperties": false
}
