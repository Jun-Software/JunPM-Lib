{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lib Schema",
  "description": "A JSON schema for JunPM.",
  "type": "object",
  "properties": {
    "name": {
      "description": "Lib Name",
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$"
    },
    "url": {
      "description": "Lib URL",
      "type": "string"
    }
  },
  "required": ["id", "url"],
  "additionalProperties": false
}
